TELEGRAM_BOT_TOKEN=         # from @BotFather
TELEGRAM_WEBHOOK_SECRET=    # random string for webhook verification
WEBHOOK_URL=                # https://your-app.onrender.com (leave empty for local polling)
GROQ_API_KEY=               # from console.groq.com
SUPABASE_URL=               # your Supabase project URL
SUPABASE_SERVICE_KEY=       # service_role key (not anon)
SUPABASE_ANON_KEY=          # anon/public key (for client-side Supabase Auth)
CRON_SECRET=                # shared secret for /cron/check endpoint
NODE_ENV=production         # set to "development" locally
GITHUB_TOKEN=               # GitHub personal access token (repo scope) for committing handoff prompts
PORT=3000
